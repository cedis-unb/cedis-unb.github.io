{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cedis.unb.br/schemas/product.schema.json",
  "title": "Produto — frontmatter de content/products/*.md",
  "description": "Frontmatter canônico de content/products/*.md após I03.",
  "type": "object",
  "required": ["title", "date", "language", "summary", "id", "status", "areas", "responsible", "publications"],
  "additionalProperties": true,
  "properties": {
    "title": {"type": "string", "minLength": 2},
    "date": {"type": "string"},
    "language": {"enum": ["pt", "en"]},
    "summary": {"type": "string"},
    "categories": {
      "type": "array",
      "items": {"type": "string"},
      "contains": {"const": "products"}
    },
    "tags": {
      "type": "array",
      "items": {"type": "string"}
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "status": {"enum": ["active", "prototype", "archived", "beta"]},
    "project": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "areas": {
      "type": "array",
      "items": {"type": "string", "pattern": "^[a-z0-9_]+$"}
    },
    "responsible": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^[a-z0-9_]+$"}
    },
    "publications": {
      "type": "array",
      "items": {"type": "string"}
    },
    "translationKey": {"type": "string"}
  }
}
