{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cedis.unb.br/schemas/area.schema.json",
  "title": "Área de atuação",
  "description": "Item do array data/areas.yaml::areas[].",
  "type": "object",
  "required": ["id", "name"],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "name": {
      "type": "object",
      "required": ["pt", "en"],
      "properties": {
        "pt": {"type": "string", "minLength": 2},
        "en": {"type": "string", "minLength": 2}
      }
    },
    "researchers": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9_]+$"
      }
    }
  }
}
