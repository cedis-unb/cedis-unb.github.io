{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cedis.unb.br/schemas/person.schema.json",
  "title": "Pessoa (não-docente) do CEDIS",
  "description": "Item de data/people.yaml::people[] — orientandos, alumni, colaboradores.",
  "type": "object",
  "required": ["name", "slug"],
  "anyOf": [
    {"required": ["categories", "advisors"]},
    {"required": ["supervisions"]}
  ],
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 3
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9_]+$"
      },
      "contains": {"const": "people"}
    },
    "advisors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9_]+$"
      }
    },
    "year": {
      "anyOf": [
        {"type": "integer", "minimum": 1990, "maximum": 2035},
        {"type": "string", "pattern": "^[0-9]{4}(/[12])?$"}
      ]
    },
    "program": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "tags": {
      "type": "array",
      "items": {"type": "string"}
    },
    "title": {
      "type": "object",
      "properties": {
        "pt": {"type": ["string", "null"]},
        "en": {"type": ["string", "null"]}
      }
    },
    "supervisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["categories", "advisors"],
        "additionalProperties": true,
        "properties": {
          "categories": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "pattern": "^[a-z0-9_]+$"},
            "contains": {"const": "people"}
          },
          "advisors": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "pattern": "^[a-z0-9_]+$"}
          },
          "tags": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    }
  }
}
