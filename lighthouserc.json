{
  "ci": {
    "collect": {
      "url": [
        "http://127.0.0.1:4173/",
        "http://127.0.0.1:4173/projects/",
        "http://127.0.0.1:4173/products/",
        "http://127.0.0.1:4173/people/sergio_freitas/",
        "http://127.0.0.1:4173/projects/framework_preditivo_engajamento/",
        "http://127.0.0.1:4173/products/edutrack/",
        "http://127.0.0.1:4173/oportunidades/",
        "http://127.0.0.1:4173/categories/news/"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "chromeFlags": "--no-sandbox --disable-dev-shm-usage"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "warn",
          {
            "minScore": 0.8
          }
        ],
        "categories:accessibility": [
          "error",
          {
            "minScore": 0.9
          }
        ],
        "categories:seo": [
          "error",
          {
            "minScore": 0.9
          }
        ],
        "categories:best-practices": [
          "error",
          {
            "minScore": 0.9
          }
        ],
        "largest-contentful-paint": [
          "warn",
          {
            "maxNumericValue": 2500
          }
        ],
        "cumulative-layout-shift": [
          "error",
          {
            "maxNumericValue": 0.1
          }
        ],
        "interactive": "off",
        "uses-long-cache-ttl": "off",
        "unsized-images": "off"
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": "lhci-report"
    }
  }
}
